<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.business.eval.mapper.ChatLogMapper">

    <resultMap type="com.ruoyi.business.eval.domain.ChatLog" id="ChatLogResult">
        <id     property="id"         column="id"          />
        <result property="sessionId"  column="session_id"  />
        <result property="question"   column="question"    />
        <result property="answer"     column="answer"      />
        <result property="intent"     column="intent"      />
        <result property="agent"      column="agent"       />
        <result property="latencyMs"  column="latency_ms"  />
        <result property="createTime" column="create_time" />
    </resultMap>

    <sql id="selectVo">
        select id, session_id, question, answer, intent, agent, latency_ms, create_time
        from cdc_chat_log
    </sql>

    <insert id="insertChatLog" parameterType="com.ruoyi.business.eval.domain.ChatLog" useGeneratedKeys="true" keyProperty="id">
        insert into cdc_chat_log (session_id, question, answer, intent, agent, latency_ms, create_time)
        values (#{sessionId}, #{question}, #{answer}, #{intent}, #{agent}, #{latencyMs}, sysdate())
    </insert>

    <select id="selectChatLogList" parameterType="com.ruoyi.business.eval.domain.ChatLog" resultMap="ChatLogResult">
        <include refid="selectVo"/>
        <where>
            <if test="intent != null and intent != ''">and intent = #{intent}</if>
            <if test="agent != null and agent != ''">and agent = #{agent}</if>
            <if test="sessionId != null and sessionId != ''">and session_id = #{sessionId}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectChatLogById" parameterType="Long" resultMap="ChatLogResult">
        <include refid="selectVo"/> where id = #{id}
    </select>

    <delete id="deleteChatLogByIds" parameterType="Long">
        delete from cdc_chat_log where id in
        <foreach collection="array" item="id" open="(" separator="," close=")">#{id}</foreach>
    </delete>
</mapper>
