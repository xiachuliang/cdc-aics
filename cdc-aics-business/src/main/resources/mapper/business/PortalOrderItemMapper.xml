<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.business.mapper.PortalOrderItemMapper">

    <resultMap type="PortalOrderItem" id="PortalOrderItemResult">
        <id     property="id"          column="id"           />
        <result property="orderId"     column="order_id"     />
        <result property="productId"   column="product_id"   />
        <result property="productName" column="product_name" />
        <result property="price"       column="price"        />
        <result property="quantity"    column="quantity"     />
        <result property="shelfArea"   column="shelf_area"   />
        <result property="subtotal"    column="subtotal"     />
    </resultMap>

    <sql id="selectPortalOrderItemVo">
        select id, order_id, product_id, product_name, price, quantity, shelf_area, subtotal
        from cdc_portal_order_item
    </sql>

    <select id="selectItemsByOrderId" parameterType="Long" resultMap="PortalOrderItemResult">
        <include refid="selectPortalOrderItemVo"/>
        where order_id = #{orderId}
    </select>

    <insert id="insertPortalOrderItem" parameterType="PortalOrderItem">
        insert into cdc_portal_order_item (
            <if test="orderId != null">order_id,</if>
            <if test="productId != null">product_id,</if>
            <if test="productName != null and productName != ''">product_name,</if>
            <if test="price != null">price,</if>
            <if test="quantity != null">quantity,</if>
            <if test="shelfArea != null and shelfArea != ''">shelf_area,</if>
            <if test="subtotal != null">subtotal,</if>
        )values(
            <if test="orderId != null">#{orderId},</if>
            <if test="productId != null">#{productId},</if>
            <if test="productName != null and productName != ''">#{productName},</if>
            <if test="price != null">#{price},</if>
            <if test="quantity != null">#{quantity},</if>
            <if test="shelfArea != null and shelfArea != ''">#{shelfArea},</if>
            <if test="subtotal != null">#{subtotal},</if>
        )
    </insert>

    <insert id="batchInsert" parameterType="java.util.List">
        insert into cdc_portal_order_item (order_id, product_id, product_name, price, quantity, shelf_area, subtotal)
        values
        <foreach collection="list" item="item" separator=",">
            (#{item.orderId}, #{item.productId}, #{item.productName}, #{item.price}, #{item.quantity}, #{item.shelfArea}, #{item.subtotal})
        </foreach>
    </insert>

</mapper>
